# 終端検出まわり
END_SILENCE_SEC=1.6     # 無音がこの秒数続いたら「終わり」とみなす（既定: SILENCE_THRESHOLD or 1.4）
HANGOVER_MS=300         # 終端判定のあと更に待つ“余韻（ハングオーバー）”ミリ秒（既定 250）
START_RMS_MULT=6.0      # 開始判定のRMSしきい値 = base_rms * START_RMS_MULT
STOP_RMS_MULT=3.2       # 終了判定のRMSしきい値 = base_rms * STOP_RMS_MULT（開始より低くしてヒステリシス）
